### TITLE ###
Rad block
### INPUT ###
ID = json[].id
Name = json[].name

rad "http":
    fields ID, Name
    sort

rad:
    fields ID, Name
    sort Name desc, ID
    ID, Name:
        color "red" "^Alice$"
        map fn(v) upper(v)
