### TITLE ###
SwitchNarrowsDiscriminantInCase
### DESCRIPTION ###
Each case body sees the discriminant narrowed to the case keys.
### INPUT ###
fn f(name: ["alice", "bob", "charlie"]):
    switch name:
        case "alice":
            a = name
        case "bob":
            b = name
        case "charlie":
            c = name
### STDOUT ###
# Identifier types
  name @ 2:12 -> ["alice", "bob", "charlie"]
  a @ 4:13 -> <no-type>
  name @ 4:17 -> ["alice"]
  b @ 6:13 -> <no-type>
  name @ 6:17 -> ["bob"]
  c @ 8:13 -> <no-type>
  name @ 8:17 -> ["charlie"]

# Symbol types
  a (local): ["alice"]
  b (local): ["bob"]
  c (local): ["charlie"]
  f (fn): fn(["alice", "bob", "charlie"]) -> void
  name (param): ["alice", "bob", "charlie"]

# Diagnostics
  (none)
### TITLE ###
SwitchMultipleKeysPerCaseUnions
### DESCRIPTION ###
case "a", "b": ... narrows the discriminant to the multi-value
sub-enum ["a", "b"] inside the case body.
### INPUT ###
fn f(name: ["a", "b", "c"]):
    switch name:
        case "a", "b":
            ab = name
        case "c":
            c = name
### STDOUT ###
# Identifier types
  name @ 2:12 -> ["a", "b", "c"]
  ab @ 4:13 -> <no-type>
  name @ 4:18 -> ["a", "b"]
  c @ 6:13 -> <no-type>
  name @ 6:17 -> ["c"]

# Symbol types
  ab (local): ["a", "b"]
  c (local): ["c"]
  f (fn): fn(["a", "b", "c"]) -> void
  name (param): ["a", "b", "c"]

# Diagnostics
  (none)
### TITLE ###
SwitchExhaustiveNoDiagnostic
### INPUT ###
fn f(name: ["a", "b"]):
    switch name:
        case "a":
            x = 1
        case "b":
            x = 2
### STDOUT ###
# Identifier types
  name @ 2:12 -> ["a", "b"]
  x @ 4:13 -> <no-type>
  x @ 6:13 -> <no-type>

# Symbol types
  f (fn): fn(["a", "b"]) -> void
  name (param): ["a", "b"]
  x (local): int

# Diagnostics
  (none)
### TITLE ###
SwitchNonExhaustiveFiresDiagnostic
### INPUT ###
fn f(name: ["a", "b", "c"]):
    switch name:
        case "a":
            x = 1
        case "b":
            x = 2
### STDOUT ###
# Identifier types
  name @ 2:12 -> ["a", "b", "c"]
  x @ 4:13 -> <no-type>
  x @ 6:13 -> <no-type>

# Symbol types
  f (fn): fn(["a", "b", "c"]) -> void
  name (param): ["a", "b", "c"]
  x (local): int

# Diagnostics
  [error] RAD40010 @ 2:5 - Switch is not exhaustive; missing case for ["c"]
### TITLE ###
SwitchDefaultSuppressesDiagnostic
### INPUT ###
fn f(name: ["a", "b", "c"]):
    switch name:
        case "a":
            x = 1
        default:
            x = 99
### STDOUT ###
# Identifier types
  name @ 2:12 -> ["a", "b", "c"]
  x @ 4:13 -> <no-type>
  x @ 6:13 -> <no-type>

# Symbol types
  f (fn): fn(["a", "b", "c"]) -> void
  name (param): ["a", "b", "c"]
  x (local): int

# Diagnostics
  (none)
### TITLE ###
SwitchOnOpenTypeSkipsExhaustiveness
### INPUT ###
fn f(name: str):
    switch name:
        case "a":
            x = 1
### STDOUT ###
# Identifier types
  name @ 2:12 -> str
  x @ 4:13 -> <no-type>

# Symbol types
  f (fn): fn(str) -> void
  name (param): str
  x (local): int

# Diagnostics
  (none)
### TITLE ###
SwitchExactDuplicateCaseFlagged
### DESCRIPTION ###
Two `case "a":` arms in the same switch - the second is
unreachable. Diagnostic points at the redundant key with the
earlier occurrence's line.
### INPUT ###
fn classify(s: str):
    switch s:
        case "a":
            x = 1
        case "a":
            x = 2
        default:
            x = 99
### STDOUT ###
# Identifier types
  s @ 2:12 -> str
  x @ 4:13 -> <no-type>
  x @ 6:13 -> <no-type>
  x @ 8:13 -> <no-type>

# Symbol types
  classify (fn): fn(str) -> void
  s (param): str
  x (local): int

# Diagnostics
  [error] RAD40012 @ 5:14 - Case is unreachable; 'a' is already matched by an earlier arm on line 3
### TITLE ###
SwitchMultiKeyOverlapFlagsRedundantKey
### DESCRIPTION ###
When a later arm shares one key with an earlier arm, only the
redundant key is flagged - not the whole case. Lets the user
fix exactly what's broken.
### INPUT ###
fn classify(s: str):
    switch s:
        case "a", "b":
            x = 1
        case "b", "c":
            x = 2
        default:
            x = 99
### STDOUT ###
# Identifier types
  s @ 2:12 -> str
  x @ 4:13 -> <no-type>
  x @ 6:13 -> <no-type>
  x @ 8:13 -> <no-type>

# Symbol types
  classify (fn): fn(str) -> void
  s (param): str
  x (local): int

# Diagnostics
  [error] RAD40012 @ 5:14 - Case is unreachable; 'b' is already matched by an earlier arm on line 3
### TITLE ###
SwitchIntDuplicateFlagged
### DESCRIPTION ###
Duplicate detection works for int keys too - the literal-key
tracker is type-tagged so `5` (int) and `"5"` (string) never
collide.
### INPUT ###
fn classify(n: int):
    switch n:
        case 1, 2:
            x = 1
        case 2:
            x = 2
        default:
            x = 99
### STDOUT ###
# Identifier types
  n @ 2:12 -> int
  x @ 4:13 -> <no-type>
  x @ 6:13 -> <no-type>
  x @ 8:13 -> <no-type>

# Symbol types
  classify (fn): fn(int) -> void
  n (param): int
  x (local): int

# Diagnostics
  [error] RAD40012 @ 5:14 - Case is unreachable; '2' is already matched by an earlier arm on line 3
### TITLE ###
SwitchVariableKeysSkipDuplicateCheck
### DESCRIPTION ###
Cases keyed by identifiers can't be statically compared, so
even when they happen to refer to the same value at runtime we
don't flag. Conservative skip preferred over false positives.
### INPUT ###
foo = "a"
bar = "a"
fn classify(s: str):
    switch s:
        case foo:
            x = 1
        case bar:
            x = 2
        default:
            x = 99
### STDOUT ###
# Identifier types
  foo @ 1:1 -> <no-type>
  bar @ 2:1 -> <no-type>
  s @ 4:12 -> str
  foo @ 5:14 -> <no-type>
  x @ 6:13 -> <no-type>
  bar @ 7:14 -> <no-type>
  x @ 8:13 -> <no-type>
  x @ 10:13 -> <no-type>

# Symbol types
  bar (local): str
  classify (fn): fn(str) -> void
  foo (local): str
  s (param): str
  x (local): int

# Diagnostics
  (none)
### TITLE ###
SwitchCaseKeyNotInEnumDiscriminantFlagged
### DESCRIPTION ###
Closed string-enum discriminant: a case key whose value is
outside the enum's value set is unreachable - the
discriminant's static type forbids it. Distinct from RAD40012
(duplicate key); this is "no value of this type ever equals
the key". Stale-arm refactor bug, e.g. an enum variant was
renamed and the old name lingers.
### INPUT ###
fn f(name: ["a", "b", "c"]):
    switch name:
        case "a":
            x = 1
        case "b":
            x = 2
        case "c":
            x = 3
        case "wat":
            x = 4
### STDOUT ###
# Identifier types
  name @ 2:12 -> ["a", "b", "c"]
  x @ 4:13 -> <no-type>
  x @ 6:13 -> <no-type>
  x @ 8:13 -> <no-type>
  x @ 10:13 -> <no-type>

# Symbol types
  f (fn): fn(["a", "b", "c"]) -> void
  name (param): ["a", "b", "c"]
  x (local): int

# Diagnostics
  [error] RAD40013 @ 9:14 - Case 'wat' is unreachable; 'name' is of type ["a", "b", "c"] and can never equal 'wat'
### TITLE ###
SwitchAllValidKeysOnEnumCleanNoDomainDiagnostic
### DESCRIPTION ###
Regression lock: when every case key lies inside the enum's
domain, no out-of-domain diagnostic fires. The check fires
only on stale/typo'd keys.
### INPUT ###
fn f(name: ["a", "b"]):
    switch name:
        case "a":
            x = 1
        case "b":
            x = 2
### STDOUT ###
# Identifier types
  name @ 2:12 -> ["a", "b"]
  x @ 4:13 -> <no-type>
  x @ 6:13 -> <no-type>

# Symbol types
  f (fn): fn(["a", "b"]) -> void
  name (param): ["a", "b"]
  x (local): int

# Diagnostics
  (none)
### TITLE ###
SwitchNonClosedDiscriminantSkipsDomainCheck
### DESCRIPTION ###
Regression lock: an open `str` discriminant has no closed
value set, so we can't say "x" can never equal "wat" - those
checks only fire on closed enums. Falls through to existing
behavior (no diagnostic).
### INPUT ###
fn f(name: str):
    switch name:
        case "a":
            x = 1
        case "wat":
            x = 2
### STDOUT ###
# Identifier types
  name @ 2:12 -> str
  x @ 4:13 -> <no-type>
  x @ 6:13 -> <no-type>

# Symbol types
  f (fn): fn(str) -> void
  name (param): str
  x (local): int

# Diagnostics
  (none)
