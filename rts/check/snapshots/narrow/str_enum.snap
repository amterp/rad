### TITLE ###
EqStrLiteralNarrowsEnum
### DESCRIPTION ###
`x == "b"` against a string-enum narrows truthy to ["b"], falsy
to the remaining values.
### INPUT ###
fn f(x: ["a", "b", "c"]):
    if x == "b":
        a = x
    else:
        b = x
### STDOUT ###
# Identifier types
  x @ 2:8 -> ["a", "b", "c"]
  a @ 3:9 -> <no-type>
  x @ 3:13 -> ["b"]
  b @ 5:9 -> <no-type>
  x @ 5:13 -> ["a", "c"]

# Symbol types
  a (local): ["b"]
  b (local): ["a", "c"]
  f (fn): fn(["a", "b", "c"]) -> void
  x (param): ["a", "b", "c"]

# Diagnostics
  (none)
### TITLE ###
NeqStrLiteralInverts
### DESCRIPTION ###
`x != "b"` swaps the partition.
### INPUT ###
fn f(x: ["a", "b", "c"]):
    if x != "b":
        a = x
    else:
        b = x
### STDOUT ###
# Identifier types
  x @ 2:8 -> ["a", "b", "c"]
  a @ 3:9 -> <no-type>
  x @ 3:13 -> ["a", "c"]
  b @ 5:9 -> <no-type>
  x @ 5:13 -> ["b"]

# Symbol types
  a (local): ["a", "c"]
  b (local): ["b"]
  f (fn): fn(["a", "b", "c"]) -> void
  x (param): ["a", "b", "c"]

# Diagnostics
  (none)
### TITLE ###
InStringListNarrows
### DESCRIPTION ###
`x in ["a", "c"]` narrows truthy to ["a", "c"], falsy to the
complement ["b"].
### INPUT ###
fn f(x: ["a", "b", "c"]):
    if x in ["a", "c"]:
        a = x
    else:
        b = x
### STDOUT ###
# Identifier types
  x @ 2:8 -> ["a", "b", "c"]
  a @ 3:9 -> <no-type>
  x @ 3:13 -> ["a", "c"]
  b @ 5:9 -> <no-type>
  x @ 5:13 -> ["b"]

# Symbol types
  a (local): ["a", "c"]
  b (local): ["b"]
  f (fn): fn(["a", "b", "c"]) -> void
  x (param): ["a", "b", "c"]

# Diagnostics
  (none)
### TITLE ###
NotInStringListInverts
### INPUT ###
fn f(x: ["a", "b", "c"]):
    if x not in ["a"]:
        rest = x
    else:
        only_a = x
### STDOUT ###
# Identifier types
  x @ 2:8 -> ["a", "b", "c"]
  rest @ 3:9 -> <no-type>
  x @ 3:16 -> ["b", "c"]
  only_a @ 5:9 -> <no-type>
  x @ 5:18 -> ["a"]

# Symbol types
  f (fn): fn(["a", "b", "c"]) -> void
  only_a (local): ["a"]
  rest (local): ["b", "c"]
  x (param): ["a", "b", "c"]

# Diagnostics
  (none)
### TITLE ###
PlainStrNotNarrowedByEquality
### DESCRIPTION ###
Plain str (not an enum) deliberately stays unchanged after `x ==
"foo"` - we don't have singleton string types.
### INPUT ###
fn f(x: str):
    if x == "foo":
        a = x
    else:
        b = x
### STDOUT ###
# Identifier types
  x @ 2:8 -> str
  a @ 3:9 -> <no-type>
  x @ 3:13 -> str
  b @ 5:9 -> <no-type>
  x @ 5:13 -> str

# Symbol types
  a (local): str
  b (local): str
  f (fn): fn(str) -> void
  x (param): str

# Diagnostics
  (none)
### TITLE ###
StrLiteralArgAcceptedByEnumParam
### DESCRIPTION ###
A plain string literal "read" synths to str, which a StrEnum
param like ["read","write"] would normally reject. Special-case
the check so a literal whose value is in the enum's set is
accepted - no false-positive Hint. The corresponding negative
case (literal not in the enum) still fires below.
### INPUT ###
fn open(mode: ["read", "write"]):
    print(mode)

open("read")
open("write")
open("append")
### STDOUT ###
# Identifier types
  print @ 2:5 -> dynamic
  mode @ 2:11 -> ["read", "write"]
  open @ 4:1 -> fn(["read", "write"]) -> void
  open @ 5:1 -> fn(["read", "write"]) -> void
  open @ 6:1 -> fn(["read", "write"]) -> void

# Symbol types
  mode (param): ["read", "write"]
  open (fn): fn(["read", "write"]) -> void

# Diagnostics
  [error] RAD30001 @ 6:6 - Argument type 'str' is not assignable to expected type '["read", "write"]'
### TITLE ###
InLiteralListUpgradesPlainStrToEnum
### DESCRIPTION ###
`if x in ["a", "b"]:` on plain `str` narrows x to the enum
["a", "b"] in the truthy branch. Falsy stays at plain str -
a str minus a finite set isn't enumerable.
### INPUT ###
fn f(x: str):
    if x in ["a", "b"]:
        a = x
    b = x
### STDOUT ###
# Identifier types
  x @ 2:8 -> str
  a @ 3:9 -> <no-type>
  x @ 3:13 -> ["a", "b"]
  b @ 4:5 -> <no-type>
  x @ 4:9 -> str

# Symbol types
  a (local): ["a", "b"]
  b (local): str
  f (fn): fn(str) -> void
  x (param): str

# Diagnostics
  (none)
### TITLE ###
NotInLiteralListNarrowsFalsyBranch
### DESCRIPTION ###
`not in` swaps: x is the enum in the FALSY branch (the
predicate failed = x was in the list = it's one of those
values). Truthy stays at plain str.
### INPUT ###
fn f(x: str):
    if x not in ["a", "b"]:
        a = x
    else:
        b = x
### STDOUT ###
# Identifier types
  x @ 2:8 -> str
  a @ 3:9 -> <no-type>
  x @ 3:13 -> str
  b @ 5:9 -> <no-type>
  x @ 5:13 -> ["a", "b"]

# Symbol types
  a (local): str
  b (local): ["a", "b"]
  f (fn): fn(str) -> void
  x (param): str

# Diagnostics
  (none)
