### TITLE ###
FnValueExactSignatureOk
### DESCRIPTION ###
A hoisted fn passed by name to a param of the same signature
matches structurally - no diagnostic. This is the headline case
Phase 7 makes possible: before, synth(identifier) returned Dynamic
and the check was silently lost.
### INPUT ###
fn cb(x: int) -> bool:
    return x > 0

fn process(callback: fn(int) -> bool):
    callback(5)

process(cb)
### STDOUT ###
# Identifier types
  x @ 2:12 -> int
  callback @ 5:5 -> fn(int) -> bool
  process @ 7:1 -> fn(fn(int) -> bool) -> void
  cb @ 7:9 -> fn(int) -> bool

# Symbol types
  callback (param): fn(int) -> bool
  cb (fn): fn(int) -> bool
  process (fn): fn(fn(int) -> bool) -> void
  x (param): int

# Diagnostics
  (none)
### TITLE ###
FnValueReturnTypeMismatchFires
### DESCRIPTION ###
Return type covariance: the supplied fn must return something
assignable to the expected return. `fn(int) -> str` can't satisfy
`fn(int) -> bool` because str is not assignable to bool.
### INPUT ###
fn cb(x: int) -> str:
    return "hi"

fn process(callback: fn(int) -> bool):
    callback(5)

process(cb)
### STDOUT ###
# Identifier types
  callback @ 5:5 -> fn(int) -> bool
  process @ 7:1 -> fn(fn(int) -> bool) -> void
  cb @ 7:9 -> fn(int) -> str

# Symbol types
  callback (param): fn(int) -> bool
  cb (fn): fn(int) -> str
  process (fn): fn(fn(int) -> bool) -> void

# Diagnostics
  [hint] RAD30001 @ 7:9 - Argument type 'fn(int) -> str' is not assignable to expected type 'fn(int) -> bool'
### TITLE ###
FnValueParamTypeMismatchFires
### DESCRIPTION ###
Param contravariance: the supplied fn's param must accept anything
the caller would pass. The caller will pass int, but the supplied
fn only accepts str - rejected.
### INPUT ###
fn cb(x: str) -> bool:
    return x != ""

fn process(callback: fn(int) -> bool):
    callback(5)

process(cb)
### STDOUT ###
# Identifier types
  x @ 2:12 -> str
  callback @ 5:5 -> fn(int) -> bool
  process @ 7:1 -> fn(fn(int) -> bool) -> void
  cb @ 7:9 -> fn(str) -> bool

# Symbol types
  callback (param): fn(int) -> bool
  cb (fn): fn(str) -> bool
  process (fn): fn(fn(int) -> bool) -> void
  x (param): str

# Diagnostics
  [hint] RAD30001 @ 7:9 - Argument type 'fn(str) -> bool' is not assignable to expected type 'fn(int) -> bool'
### TITLE ###
FnValueWiderParamOkContravariance
### DESCRIPTION ###
Contravariance allows wider params: a `fn(any) -> bool` can stand
in where `fn(int) -> bool` is expected. The supplied fn's any
param accepts the int the caller will supply.
### INPUT ###
fn cb(x: any) -> bool:
    return true

fn process(callback: fn(int) -> bool):
    callback(5)

process(cb)
### STDOUT ###
# Identifier types
  callback @ 5:5 -> fn(int) -> bool
  process @ 7:1 -> fn(fn(int) -> bool) -> void
  cb @ 7:9 -> fn(any) -> bool

# Symbol types
  callback (param): fn(int) -> bool
  cb (fn): fn(any) -> bool
  process (fn): fn(fn(int) -> bool) -> void

# Diagnostics
  (none)
### TITLE ###
FnValueArityMismatchFires
### DESCRIPTION ###
Different number of params - rejected. The receiver expects one
arg, the supplied fn takes two; no way to call the supplied fn
with a single int.
### INPUT ###
fn cb(x: int, y: int) -> bool:
    return x > y

fn process(callback: fn(int) -> bool):
    callback(5)

process(cb)
### STDOUT ###
# Identifier types
  x @ 2:12 -> int
  y @ 2:16 -> int
  callback @ 5:5 -> fn(int) -> bool
  process @ 7:1 -> fn(fn(int) -> bool) -> void
  cb @ 7:9 -> fn(int, int) -> bool

# Symbol types
  callback (param): fn(int) -> bool
  cb (fn): fn(int, int) -> bool
  process (fn): fn(fn(int) -> bool) -> void
  x (param): int
  y (param): int

# Diagnostics
  [hint] RAD30001 @ 7:9 - Argument type 'fn(int, int) -> bool' is not assignable to expected type 'fn(int) -> bool'
### TITLE ###
FnValueUntypedParamAcceptsAnything
### DESCRIPTION ###
When the receiver param is unannotated, anything goes - the param
is effectively `any`, no structural check fires. Gradual typing
escape hatch.
### INPUT ###
fn cb(x: str) -> str:
    return x

fn process(callback):
    callback("hi")

process(cb)
### STDOUT ###
# Identifier types
  x @ 2:12 -> str
  callback @ 5:5 -> dynamic
  process @ 7:1 -> fn(any) -> void
  cb @ 7:9 -> fn(str) -> str

# Symbol types
  callback (param): <no-type>
  cb (fn): fn(str) -> str
  process (fn): fn(any) -> void
  x (param): str

# Diagnostics
  (none)
### TITLE ###
LambdaExprWrongReturnTypeFires
### DESCRIPTION ###
Expression-form lambda `fn(x) "hi"` infers `fn(any) -> str`. The
expression body IS the return value, so we synth it directly. The
mismatch with `fn(int) -> bool` fires - this is the first case the
old "lambda synths to Dynamic" caveat blocked.
### INPUT ###
fn process(callback: fn(int) -> bool):
    callback(5)

process(fn(x) "hi")
### STDOUT ###
# Identifier types
  callback @ 2:5 -> fn(int) -> bool
  process @ 4:1 -> fn(fn(int) -> bool) -> void

# Symbol types
  callback (param): fn(int) -> bool
  process (fn): fn(fn(int) -> bool) -> void

# Diagnostics
  [hint] RAD30001 @ 4:9 - Argument type 'fn(any) -> str' is not assignable to expected type 'fn(int) -> bool'
### TITLE ###
LambdaExprRightShapeOk
### DESCRIPTION ###
Lambda whose inferred return matches the expected signature -
no diagnostic. `fn(x) x > 0` infers `fn(any) -> bool` and slots
into `fn(int) -> bool` cleanly (contravariant param: any accepts
int; covariant return: bool matches bool).
### INPUT ###
fn process(callback: fn(int) -> bool):
    callback(5)

process(fn(x) x > 0)
### STDOUT ###
# Identifier types
  callback @ 2:5 -> fn(int) -> bool
  process @ 4:1 -> fn(fn(int) -> bool) -> void
  x @ 4:15 -> dynamic

# Symbol types
  callback (param): fn(int) -> bool
  process (fn): fn(fn(int) -> bool) -> void
  x (param): <no-type>

# Diagnostics
  (none)
### TITLE ###
LambdaBlockMultiPathReturnUnioned
### DESCRIPTION ###
A block-form lambda with two return paths gets a union return
type. With no annotation, inference unions the return arms into
`int|str`, neither of which is bool - the call fires.
### INPUT ###
fn process(callback: fn(int) -> bool):
    callback(5)

process(fn(x):
    if x > 0:
        return 1
    return "hi"
)
### STDOUT ###
# Identifier types
  callback @ 2:5 -> fn(int) -> bool
  process @ 4:1 -> fn(fn(int) -> bool) -> void
  x @ 5:8 -> dynamic

# Symbol types
  callback (param): fn(int) -> bool
  process (fn): fn(fn(int) -> bool) -> void
  x (param): <no-type>

# Diagnostics
  [hint] RAD30001 @ 4:9 - Argument type 'fn(any) -> int|str' is not assignable to expected type 'fn(int) -> bool'
### TITLE ###
LambdaBlockNoReturnIsVoid
### DESCRIPTION ###
A lambda with no `return` statement infers `void` as the return.
That doesn't match `fn(int) -> bool`, so the slot fires.
### INPUT ###
fn process(callback: fn(int) -> bool):
    callback(5)

process(fn(x):
    print(x)
)
### STDOUT ###
# Identifier types
  callback @ 2:5 -> fn(int) -> bool
  process @ 4:1 -> fn(fn(int) -> bool) -> void
  print @ 5:5 -> dynamic
  x @ 5:11 -> dynamic

# Symbol types
  callback (param): fn(int) -> bool
  process (fn): fn(fn(int) -> bool) -> void
  x (param): <no-type>

# Diagnostics
  [hint] RAD30001 @ 4:9 - Argument type 'fn(any) -> void' is not assignable to expected type 'fn(int) -> bool'
### TITLE ###
LambdaDeclaredReturnMismatchFiresAtReturn
### DESCRIPTION ###
When the user writes a return annotation (`-> bool`) we honor it
AND check each `return E` against it at the return statement's
span (not at the call site). Here the body returns "hi" (str)
where bool was promised - the diagnostic lands on the return,
which is the right place to point the user.
### INPUT ###
fn process(callback: fn(int) -> bool):
    callback(5)

process(fn(x) -> bool: return "hi")
### STDOUT ###
# Identifier types
  callback @ 2:5 -> fn(int) -> bool
  process @ 4:1 -> fn(fn(int) -> bool) -> void

# Symbol types
  callback (param): fn(int) -> bool
  process (fn): fn(fn(int) -> bool) -> void

# Diagnostics
  [error] RAD10001 @ 4:22 - Invalid function syntax
  [hint] RAD30001 @ 4:31 - Return value of type 'str' is not assignable to declared return type 'bool'
