### TITLE ###
[F12] Assignment spacing
### INPUT ###
x=1
y   =   2
### STDOUT ###
x = 1
y = 2
### TITLE ###
[F13] Multi-assign
### INPUT ###
a,b ,c = f()
### STDOUT ###
a, b, c = f()
### TITLE ###
[F14][F15] Compound assign and increment/decrement
### INPUT ###
x  +=  1
y -=2
i++
j  --
### STDOUT ###
x += 1
y -= 2
i++
j--
### TITLE ###
[F20] Arithmetic operators
### INPUT ###
x = 1+2*3-4/5%6
### STDOUT ###
x = 1 + 2 * 3 - 4 / 5 % 6
### TITLE ###
[F20][F21] Boolean, comparison, and unary not
### INPUT ###
ok = a>1 and b==2 or not c
### STDOUT ###
ok = a > 1 and b == 2 or not c
### TITLE ###
[F31] Typed assignment
### INPUT ###
x:int=1
msg : str = "hi"
### STDOUT ###
x: int = 1
msg: str = "hi"
