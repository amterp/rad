### TITLE ###
List spacing
### INPUT ###
l = [ 1,2 ,3 ]
### STDOUT ###
l = [1, 2, 3]
### TITLE ###
Nested lists
### INPUT ###
m = [[1,2],[3 ,4]]
### STDOUT ###
m = [[1, 2], [3, 4]]
### TITLE ###
Map spacing
### INPUT ###
m = {"x":1,  y :2}
### STDOUT ###
m = {"x": 1, y: 2}
### TITLE ###
Empty collections
### INPUT ###
a = [  ]
b = {  }
c = f(  )
### STDOUT ###
a = []
b = {}
c = f()
### TITLE ###
Long list wraps one per line
### INPUT ###
items = ["alpha", "bravo", "charlie", "delta", "echo", "foxtrot", "golf", "hotel", "india", "juliet", "kilo"]
### STDOUT ###
items = [
    "alpha",
    "bravo",
    "charlie",
    "delta",
    "echo",
    "foxtrot",
    "golf",
    "hotel",
    "india",
    "juliet",
    "kilo",
]
