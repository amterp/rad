### TITLE ###
[F17] If / else-if / else chain
### INPUT ###
if x>1:
    print(1)
else if y:
    print(2)
else:
    print(3)
### STDOUT ###
if x > 1:
    print(1)
else if y:
    print(2)
else:
    print(3)
### TITLE ###
[F18] For loop
### INPUT ###
for i in range(3):
    print(i)
### STDOUT ###
for i in range(3):
    print(i)
### TITLE ###
[F18] For loop with multiple vars
### INPUT ###
for i,x in items:
    print(x)
### STDOUT ###
for i, x in items:
    print(x)
### TITLE ###
[F43] For loop with context clause
### INPUT ###
for x in [1,2,3]  with  loop:
    print(loop.idx)
### STDOUT ###
for x in [1, 2, 3] with loop:
    print(loop.idx)
### TITLE ###
[F43] Keyed for loop with context clause
### INPUT ###
for k,v in m with loop:
    print(loop.idx, k, v)
### STDOUT ###
for k, v in m with loop:
    print(loop.idx, k, v)
### TITLE ###
[F19] While loop
### INPUT ###
while x:
    x=x-1
### STDOUT ###
while x:
    x = x - 1
### TITLE ###
[F1][F17][F18] Nested blocks indent four spaces
### INPUT ###
if a:
    for i in xs:
        if i>0:
            print(i)
### STDOUT ###
if a:
    for i in xs:
        if i > 0:
            print(i)
