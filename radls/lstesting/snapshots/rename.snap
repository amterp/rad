### TITLE ###
RenameLocalFromDeclSite
### DOCUMENT ###
x = 1
print(x)
print(x + 1)
### RENAME 0:0 y ###
### STDOUT ###
{
  "jsonrpc": "2.0",
  "method": "textDocument/publishDiagnostics",
  "params": {
    "diagnostics": [],
    "uri": "file:///test.rad"
  }
}

{
  "id": 1,
  "jsonrpc": "2.0",
  "result": {
    "changes": {
      "file:///test.rad": [
        {
          "newText": "y",
          "range": {
            "end": {
              "character": 1,
              "line": 0
            },
            "start": {
              "character": 0,
              "line": 0
            }
          }
        },
        {
          "newText": "y",
          "range": {
            "end": {
              "character": 7,
              "line": 1
            },
            "start": {
              "character": 6,
              "line": 1
            }
          }
        },
        {
          "newText": "y",
          "range": {
            "end": {
              "character": 7,
              "line": 2
            },
            "start": {
              "character": 6,
              "line": 2
            }
          }
        }
      ]
    }
  }
}
