  "jsonrpc": "2.0",
  "method": "textDocument/publishDiagnostics",
  "params": {
    "diagnostics": [],
    "uri": "file:///test.rad"
  }
}

{
  "id": 1,
  "jsonrpc": "2.0",
  "result": {
    "changes": {
      "file:///test.rad": [
        {
          "newText": "say_hi",
          "range": {
            "end": {
              "character": 8,
              "line": 0
            },
            "start": {
              "character": 3,
              "line": 0
            }
          }
        },
        {
          "newText": "say_hi",
          "range": {
            "end": {
              "character": 5,
              "line": 3
            },
            "start": {
              "character": 0,
              "line": 3
            }
          }
        },
        {
          "newText": "say_hi",
          "range": {
            "end": {
              "character": 5,
              "line": 4
            },
            "start": {
              "character": 0,
              "line": 4
            }
          }
        }
      ]
    }
  }
}
