### TITLE ###
FixSyntaxError
### DOCUMENT ###
x =
### CHANGE ###
x = 1
### STDOUT ###
{
  "jsonrpc": "2.0",
  "method": "textDocument/publishDiagnostics",
  "params": {
    "diagnostics": [
      {
        "message": "Unexpected 'x ='",
        "range": {
          "end": {
            "character": 3,
            "line": 0
          },
          "start": {
            "character": 0,
            "line": 0
          }
        },
        "severity": 1,
        "source": "Rad Language Server"
      }
    ],
    "uri": "file:///test.rad"
  }
}

{
  "jsonrpc": "2.0",
  "method": "textDocument/publishDiagnostics",
  "params": {
    "diagnostics": [],
    "uri": "file:///test.rad"
  }
}
