### TITLE ###
ChangePreservesComplexDiagnostics
### DOCUMENT ###
x = 1
### CHANGE ###
x =
foo()
### STDOUT ###
{
  "jsonrpc": "2.0",
  "method": "textDocument/publishDiagnostics",
  "params": {
    "diagnostics": [],
    "uri": "file:///test.rad"
  }
}

{
  "jsonrpc": "2.0",
  "method": "textDocument/publishDiagnostics",
  "params": {
    "diagnostics": [
      {
        "message": "Function 'foo' may not be defined (only built-in and top-level functions are tracked)",
        "range": {
          "end": {
            "character": 3,
            "line": 1
          },
          "start": {
            "character": 0,
            "line": 1
          }
        },
        "severity": 4,
        "source": "Rad Language Server"
      }
    ],
    "uri": "file:///test.rad"
  }
}
