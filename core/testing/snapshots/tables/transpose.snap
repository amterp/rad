### TITLE ###
Transpose basic
### INPUT ###
Name = ["Alice", "Bob"]
Age = [30, 40]
rad:
    transpose
    fields Name, Age
### STDOUT ###
Name  Alice  Bob  
Age   30     40   

### TITLE ###
Transpose with explicit true
### INPUT ###
Name = ["Alice", "Bob", "Charlie"]
Age = [30, 40, 25]
rad:
    transpose true
    fields Name, Age
### STDOUT ###
Name  Alice  Bob  Charlie  
Age   30     40   25       

### TITLE ###
Transpose with explicit false
### INPUT ###
Name = ["Alice", "Bob"]
Age = [30, 40]
rad:
    transpose false
    fields Name, Age
### STDOUT ###
Name   Age 
Alice  30   
Bob    40   

### TITLE ###
Transpose with expression
### INPUT ###
Name = ["Alice", "Bob"]
Age = [30, 40]
should_transpose = true
rad:
    transpose should_transpose
    fields Name, Age
### STDOUT ###
Name  Alice  Bob  
Age   30     40   

### TITLE ###
Transpose inside if block
### INPUT ###
Name = ["Alice", "Bob"]
Age = [30, 40]
do_transpose = true
rad:
    fields Name, Age
    if do_transpose:
        transpose
### STDOUT ###
Name  Alice  Bob  
Age   30     40   

### TITLE ###
Transpose with sort
### INPUT ###
Name = ["Charlie", "Alice", "Bob"]
Age = [25, 30, 40]
rad:
    transpose
    sort Name asc
    fields Name, Age
### STDOUT ###
Name  Alice  Bob  Charlie  
Age   30     40   25       

### TITLE ###
Transpose single row
### INPUT ###
Name = ["Alice"]
Age = [30]
rad:
    transpose
    fields Name, Age
### STDOUT ###
Name  Alice  
Age   30     

### TITLE ###
Transpose with missing values
### INPUT ###
Name = ["Alice", "Bob", "Charlie"]
Age = [30, 40]
rad:
    transpose
    fields Name, Age
### STDOUT ###
Name  Alice  Bob  Charlie  
Age   30     40            

### TITLE ###
Transpose with color
### INPUT ###
Name = ["Alice", "Bob"]
Age = [30, 40]
rad:
    transpose
    fields Name, Age
    Name:
        color "red" ".*"
### STDOUT ###
Name  Alice  Bob  
Age   30     40   

### TITLE ###
Transpose with noprint
### INPUT ###
Name = ["Alice", "Bob"]
Age = [30, 40]
rad:
    transpose
    noprint
    fields Name, Age
print("Names:", Name)
### STDOUT ###
Names: [ "Alice", "Bob" ]

### TITLE ###
Transpose with color enabled
### INPUT ###
Name = ["Alice", "Bob"]
Age = [30, 40]
rad:
    transpose
    fields Name, Age
    Name:
        color "red" ".*"
### ARGS ###
--color=always
### STDOUT ###
[33mName[0m  [31mAlice[0m  [31mBob[0m  
[33mAge[0m   30     40   

### TITLE ###
Transpose with color on multiple columns
### INPUT ###
Name = ["Alice", "Bob"]
Age = [30, 40]
rad:
    transpose
    fields Name, Age
    Name:
        color "red" "Alice"
    Age:
        color "green" "40"
### ARGS ###
--color=always
### STDOUT ###
[33mName[0m  [31mAlice[0m  Bob  
[33mAge[0m   30     [32m40[0m   

### TITLE ###
Transpose with color regex partial match
### INPUT ###
Name = ["Alice", "Bob"]
Age = [30, 40]
rad:
    transpose
    fields Name, Age
    Name:
        color "blue" "li"
### ARGS ###
--color=always
### STDOUT ###
[33mName[0m  A[34mli[0mce  Bob  
[33mAge[0m   30     40   

### TITLE ###
Transpose false with color
### INPUT ###
Name = ["Alice", "Bob"]
Age = [30, 40]
rad:
    transpose false
    fields Name, Age
    Name:
        color "red" ".*"
### STDOUT ###
Name   Age 
Alice  30   
Bob    40   

