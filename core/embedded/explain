#!/usr/bin/env rad
---
Explains Rad error codes. Deprecated - use 'rad docs' instead.

This command still works but will be removed in a future version.
Prefer:
> rad docs RAD10001          # explain a specific error code
> rad docs reference/errors  # the full error reference
---
args:
    code str  # The error code to explain (e.g., RAD10001, 10001, or 'list').

print_err("Note: 'rad explain' is deprecated; use 'rad docs' instead (e.g. 'rad docs RAD10001'). It will be removed in a future version.")

// Handle "list" subcommand
if code == "list":
    codes = _rad_explain_list()
    print("Available error codes:".bold())
    for c in codes:
        print("  " + "RAD{c}".red())
    exit(0)

// Normalize the code - strip RAD prefix if present
normalized = code
if code.starts_with("RAD"):
    normalized = code[3:]

doc = _rad_explain(normalized)
if doc == null:
    print_err("Unknown error code: {code}")
    print_err("Run 'rad docs reference/errors' to see all available error codes.")
    exit(1)

print(doc)
